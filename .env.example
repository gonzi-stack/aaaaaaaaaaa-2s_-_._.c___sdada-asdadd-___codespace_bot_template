# =============================================
# Discord Bot Configuration
# =============================================

# Token del bot de Discord (obligatorio)
DISCORD_TOKEN=

# ID de aplicación de Discord (obligatorio para registro de slash commands)
DISCORD_CLIENT_ID=

# ID del servidor de desarrollo (opcional — para comandos guild-scoped en dev)
DISCORD_DEV_GUILD_ID=

# Prefijo por defecto para comandos de texto
DEFAULT_PREFIX=!

# =============================================
# Base de datos MariaDB / MySQL
# =============================================

DB_HOST=
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_NAME=

# Máximo de conexiones en el pool
DB_POOL_MAX=20

# =============================================
# Redis
# =============================================

# URL de conexión Redis
REDIS_URL=redis://localhost:6379

# =============================================
# Entorno
# =============================================

# Entorno de ejecución: development | production
NODE_ENV=development

# Puerto del servidor de health check
HEALTH_PORT=3000

# IPs autorizadas para acceder a la API del bot (separadas por coma)
API_ALLOWED_IPS=

# =============================================
# Logging
# =============================================

# Nivel de log: trace | debug | info | warn | error | fatal
LOG_LEVEL=info
