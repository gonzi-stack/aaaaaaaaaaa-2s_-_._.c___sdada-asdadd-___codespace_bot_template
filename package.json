{
  "name": "discordbot-template",
  "version": "1.0.0",
  "description": "Professional Discord bot template — Discord.js v14.25.1, TypeScript, MariaDB, Redis",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "postinstall": "pnpm run build",
    "build": "tsup",
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "migrate": "tsx src/db/run-migrations.ts"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.32.1",
  "dependencies": {
    "@discordjs/rest": "^2.4.3",
    "discord.js": "14.25.1",
    "dotenv": "^16.4.7",
    "ioredis": "^5.4.2",
    "mysql2": "^3.18.2",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.12",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "eslint": "^8.57.1",
    "tsup": "^8.3.6",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}